# Trinity — пример переменных окружения.
# Скопируйте в .env и заполните по необходимости.
# Все эти поля ОПЦИОНАЛЬНЫ — кредентиалы обычно вводятся через форму.

# Секрет для подписи сессионных cookie.
# ОБЯЗАТЕЛЬНО смените в production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-in-production-please-use-strong-secret

# Директория, в которой ExecutorAgent может работать с файлами
# (по умолчанию — текущая директория).
WORKSPACE_DIR=.

# Таймаут LLM-запросов в секундах
LLM_TIMEOUT_SECONDS=120

# Макс. итераций в цикле Planner↔Critic
MAX_ITERATIONS=5

# Trinity — пример переменных окружения.
#
# Скопируйте в .env и заполните по необходимости:
#     cp .env.example .env
#
# ─────────────────────────────────────────────────────────────────
# ⚠️  ВАЖНО ПРО API-КЛЮЧИ
# ─────────────────────────────────────────────────────────────────
# В проде ключи NVIDIA вводятся через форму на главной странице
# и хранятся в подписанной cookie-сессии. В .env их класть НЕ НАДО.
#
# Поля *_API_KEY ниже — это ОПЦИОНАЛЬНЫЙ fallback для:
#   • headless-сценариев (CI, скрипты, без UI);
#   • локальной разработки, когда не хочется каждый раз вбивать ключ.
# Если они не заданы — менеджер подскажет, что нужно открыть форму.
# ─────────────────────────────────────────────────────────────────

# ── Сессия ──────────────────────────────────────────────────────
# Секрет для подписи cookie. ОБЯЗАТЕЛЬНО смените в production:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=change-me-in-production-please-use-strong-secret

# ── Workspace (Sandbox) ────────────────────────────────────────
# Директория, в которой ExecutorAgent может читать и писать файлы.
# Все пути, которые передаёт LLM, резолвятся через Path.resolve()
# и проверяются, что остаются внутри этой папки.
#   • "."   — текущая директория (по умолчанию)
#   • абсолютный путь, например /home/david/projects/sandbox
WORKSPACE_DIR=.

# ── LLM-провайдеры ─────────────────────────────────────────────
# Таймаут HTTP-запросов к NVIDIA / Ollama, в секундах.
LLM_TIMEOUT_SECONDS=120

# Максимум итераций в цикле Planner → Critic → Executor.
MAX_ITERATIONS=5

# ── NVIDIA NIM (опционально) ───────────────────────────────────
# По умолчанию — публичный endpoint integrate.api.nvidia.com.
# Если у вас приватный деплой — переопределите *_BASE_URL.
PLANNER_BASE_URL=https://integrate.api.nvidia.com/v1
CRITIC_BASE_URL=https://integrate.api.nvidia.com/v1

# ── OpenAI / Anthropic / Google Gemini (опционально) ───────────
# Если провайдер gpt, можно не указывать BASE_URL (будет https://api.openai.com/v1)
# Если anthropic, можно не указывать (будет https://api.anthropic.com/v1)
# Если google, можно не указывать (будет https://generativelanguage.googleapis.com/v1beta)
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# GOOGLE_API_KEY=

# Имена моделей по умолчанию (можно переопределить через форму).
PLANNER_MODEL=abacusai/dracarys-llama-3.1-70b-instruct
CRITIC_MODEL=google/gemma-2-27b-it
EXECUTOR_MODEL=qwen2.5-coder

# ⚠️  Ключи ниже — НЕ заполняйте в production. Только для локальной
# разработки. В проде ключи вводятся через форму и хранятся в сессии.
PLANNER_API_KEY=
CRITIC_API_KEY=

# ── Ollama (локальная LLM для Executor) ────────────────────────
# Адрес локального Ollama-сервера.
OLLAMA_URL=http://localhost:11434
